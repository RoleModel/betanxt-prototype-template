# Example environment variables
# Copy this file to .env.local and fill in your actual values

# GitHub Personal Access Token for BetaNXT Design System
# Required for accessing @rolemodel/betanxt-design-system from GitHub registry
# Generate a token with 'read:packages' permission at: https://github.com/settings/tokens
GITHUB_TOKEN=your_personal_access_token_here

# Next.js Environment
NODE_ENV=development

# Add other environment variables your application needs
# DATABASE_URL=your_database_url
# API_URL=your_api_url
# NEXTAUTH_SECRET=your_nextauth_secret
